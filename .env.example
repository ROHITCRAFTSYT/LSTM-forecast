# Copy to .env and fill in. The .env file is gitignored.
# All variables are OPTIONAL — the forecasting core and RAG retrieval run without any of them.

# ---------------------------------------------------------------------------
# AI layer — provider-agnostic (insights, chat assistant, LLM-assisted tuning).
# Without a usable provider, AI features degrade gracefully and everything else works.
# ---------------------------------------------------------------------------
# Provider: anthropic | openai | google | ollama | openai_compatible
LSTM_FORECAST_AI__PROVIDER=anthropic

# API key for the selected provider. ANTHROPIC_API_KEY / OPENAI_API_KEY / GOOGLE_API_KEY
# are also picked up automatically; or set the generic one below.
LSTM_FORECAST_AI__API_KEY=
ANTHROPIC_API_KEY=

# Model id (leave empty to use the provider's default, e.g. claude-opus-4-8 / gpt-4o /
# gemini-1.5-pro / llama3.1).
LSTM_FORECAST_AI__MODEL=
# Reasoning effort (Anthropic only): low | medium | high | max
LSTM_FORECAST_AI__EFFORT=high
# Custom endpoint for openai_compatible / ollama (e.g. http://localhost:11434/v1,
# https://openrouter.ai/api/v1). Leave empty for the provider default.
LSTM_FORECAST_AI__BASE_URL=

# Examples:
#   OpenAI:        LSTM_FORECAST_AI__PROVIDER=openai      + OPENAI_API_KEY=...
#   Gemini:        LSTM_FORECAST_AI__PROVIDER=google      + GOOGLE_API_KEY=...
#   Local Ollama:  LSTM_FORECAST_AI__PROVIDER=ollama      + LSTM_FORECAST_AI__MODEL=llama3.1  (no key)
#   OpenRouter:    LSTM_FORECAST_AI__PROVIDER=openai_compatible + LSTM_FORECAST_AI__BASE_URL=https://openrouter.ai/api/v1 + LSTM_FORECAST_AI__API_KEY=...

# ---------------------------------------------------------------------------
# Runtime / paths
# ---------------------------------------------------------------------------
# Where data downloads and artifacts (vector indices, trained models) are cached.
LSTM_FORECAST_CACHE_DIR=.cache
# torch device: "auto" | "cpu" | "cuda" | "mps"
LSTM_FORECAST_DEVICE=auto
# Global random seed for reproducibility.
LSTM_FORECAST_SEED=20

# ---------------------------------------------------------------------------
# API service
# ---------------------------------------------------------------------------
LSTM_FORECAST_API__HOST=0.0.0.0
LSTM_FORECAST_API__PORT=8000
# Comma-separated CORS origins, or "*" for all.
LSTM_FORECAST_API__CORS_ORIGINS=*
